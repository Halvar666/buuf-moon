<?xml version="1.0"?>

<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:em="http://www.mozilla.org/2004/em-rdf#">

  <Description about="urn:mozilla:install-manifest">
    <em:id>buufmoon@halvar666</em:id>
    <em:version>1.0.0beta1</em:version>
    <em:name>Buuf Moon</em:name>
    <em:description>Classic Buuf visual style rebuilt for Pale Moon. Non-commercial beta release.</em:description>
    <em:creator>Halvar666</em:creator>
    <em:type>4</em:type>
    <em:internalName>buufmoon</em:internalName>
    <em:skinnable>true</em:skinnable>

    <em:contributor>terpmeister - original My Buuf Firefox theme</em:contributor>
    <em:contributor>mattahan - original Buuf icon artwork</em:contributor>
    <em:contributor>niivu - Buuf Remastered icon theme / updated port</em:contributor>
    <em:contributor>Lootyhoof - Camimoon Pale Moon theme template</em:contributor>
    <em:contributor>Camino Project / Murphy / tylerc.com - Camimoon source credits</em:contributor>

    <em:targetApplication>
      <!-- Pale Moon -->
      <Description>
        <em:id>{8de7fcbb-c55c-4fbe-bfc5-fc555c87dbc4}</em:id>
        <em:minVersion>29.3.0</em:minVersion>
        <em:maxVersion>34.*</em:maxVersion>
      </Description>
    </em:targetApplication>

  </Description>
</RDF>
